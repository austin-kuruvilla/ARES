# Files that should stay outside version control.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
*.tsbuildinfo
/dist/
/.wrangler/
/outputs/
/work/

# local project material
/AGENTS.md
/DEMO*.md
/.agents/
/.openai/hosting.json
/artifacts/
/plugins/arc-cyber-decision-engine/skills/arc-cyber-decision-engine/references/judge-demo.md
